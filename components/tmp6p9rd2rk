def plot_acf_pacf(acf_data: dict) -> go.Figure:
    from plotly.subplots import make_subplots

    lags         = acf_data["lags"]
    conf         = acf_data["conf"]
    series_label = "Idiosyncratic" if acf_data["series"] == "idio" else "Total"

    fig = make_subplots(
        rows=1, cols=2,
        horizontal_spacing=0.12,
    )

    for col, key in enumerate(["acf", "pacf"], start=1):
        vals = acf_data[key]

        fig.add_hrect(
            y0=-conf, y1=conf,
            fillcolor = _hex_to_rgba(THEME["primary"], 0.06),
            line_width= 0,
            row=1, col=col,
        )
        for y_val in [conf, -conf]:
            fig.add_hline(
                y    = y_val,
                line = dict(color=THEME["primary"], width=1, dash="dash"),
                row=1, col=col,
            )
        fig.add_hline(
            y    = 0,
            line = dict(color=THEME["border_subtle"], width=1),
            row=1, col=col,
        )

        bar_colors = [
            THEME["primary"] if abs(v) > conf else THEME["grid"]
            for v in vals
        ]
        fig.add_trace(go.Bar(
            x             = lags,
            y             = vals,
            name          = key.upper(),
            marker_color  = bar_colors,
            showlegend    = False,
            width         = 0.4,
            hovertemplate = f"Lag %{{x}}<br>{key.upper()}: %{{y:.3f}}<extra></extra>",
        ), row=1, col=col)

    apply_base_layout(
        fig,
        height   = 260,
        margin   = dict(t=44, b=30, l=40, r=20),
        hovermode= "x unified",
        dragmode = False,
    )

    # Subplot title annotations
    fig.add_annotation(dict(
        text="ACF", x=0.22, y=1.0,
        xref="paper", yref="paper",
        xanchor="center", yanchor="bottom",
        showarrow=False,
        font=dict(size=THEME["font_size_body"],
                  color=THEME["text_primary"],
                  family=THEME["font_family"]),
    ))
    fig.add_annotation(dict(
        text="PACF", x=0.82, y=1.0,
        xref="paper", yref="paper",
        xanchor="center", yanchor="bottom",
        showarrow=False,
        font=dict(size=THEME["font_size_body"],
                  color=THEME["text_primary"],
                  family=THEME["font_family"]),
    ))
    # Main title
    fig.add_annotation(
        _title_annotation(
            f"{series_label} Returns — {max(lags)} lags, dashed = 95% band",
            size=THEME["font_size_body"],
        )
    )

    fig.update_xaxes(
        title    = dict(text="Lag", font=dict(size=THEME["font_size_body"])),
        fixedrange=True,
    )
    fig.update_yaxes(fixedrange=True)
    return fig


