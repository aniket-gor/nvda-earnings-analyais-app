def plot_correlation_heatmap(
    corr_data: dict,
    selected_pair: tuple = None,
) -> go.Figure:
    z      = corr_data["z"].copy()
    labels = corr_data["labels"]
    n      = len(labels)

    text = [
        [f"{z[i,j]:.2f}" if j > i and not np.isnan(z[i,j]) else ""
         for j in range(n)]
        for i in range(n)
    ]

    z_plot = z.astype(object)
    for i in range(n):
        for j in range(i):
            z_plot[i, j] = None
        z_plot[i, i] = None

    fig = go.Figure(go.Heatmap(
        z             = z_plot,
        x             = labels,
        y             = labels,
        text          = text,
        texttemplate  = "%{text}",
        textfont      = dict(size=THEME["font_size_body"],
                             color=THEME["text_primary"]),
        colorscale    = DIVERGING_CORR,
        showscale     = False,
        zmid=0, zmin=-1, zmax=1,
        hovertemplate = (
            "<b>%{y}</b> × <b>%{x}</b><br>"
            "r = %{z:.2f}<extra></extra>"
        ),
    ))

    car_count = len(SCATTER_CAR_OFFSETS)
    for x0, x1, y0, y1 in [
        (car_count-0.5, n-0.5,        car_count-0.5, car_count-0.5),
        (car_count-0.5, car_count-0.5, -0.5,          car_count-0.5),
    ]:
        fig.add_shape(
            type="line",
            x0=x0, x1=x1, y0=y0, y1=y1,
            xref="x", yref="y",
            line=dict(color=THEME["neutral"], width=1, dash="dot"),
        )

    apply_base_layout(
        fig,
        title    = "Metric Correlation Matrix",
        height   = 400,
        margin   = dict(t=44, b=10, l=80, r=10),
        dragmode = False,
    )

    fig.update_xaxes(tickangle=-45, fixedrange=True, side="bottom")
    fig.update_yaxes(autorange="reversed", fixedrange=True)
    return fig


