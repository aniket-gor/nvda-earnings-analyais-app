def plot_earnings_factor_heatmap(
    decomp: dict,
    selected_event: str = None,
) -> go.Figure:
    if selected_event and selected_event in decomp["per_event"]:
        df_plot = decomp["per_event"][selected_event]
        title   = f"Factor Decomposition — {selected_event}"
    else:
        df_plot = decomp["average"]
        title   = "Factor Decomposition — Average (All Events)"

    factors = (
        [f for f in df_plot.index if f not in ("Idiosyncratic", "NVDA Total")]
        + ["Idiosyncratic", "NVDA Total"]
    )
    df_plot = df_plot.reindex(factors)
    z       = df_plot.values.astype(float)
    max_val = float(np.abs(z[~np.isnan(z)]).max()) if z.size > 0 else 1.0
    snap_labels = decomp["snap_labels"]

    fig = go.Figure(go.Heatmap(
        z             = z,
        x             = snap_labels,
        y             = factors,
        showscale     = False,
        text          = [[f"{v:+.1f}%" if not np.isnan(v) else "—" for v in row] for row in z],
        texttemplate  = "%{text}",
        textfont      = dict(size=THEME["font_size_cell"],
                             color=THEME["text_primary"]),
        colorscale    = DIVERGING_RdGn,
        zmid=0,
        zmin=-max_val,
        zmax=max_val,
        hovertemplate = (
            "<b>%{y}</b><br>%{x}<br>"
            "Cum. Contribution: %{z:.2f}%<extra></extra>"
        ),
    ))

    if "D0" in snap_labels:
        d0_pos = snap_labels.index("D0")
        fig.add_shape(
            type="line",
            x0=d0_pos + 0.5, x1=d0_pos + 0.5,
            y0=-0.5,          y1=len(factors) - 0.5,
            xref="x", yref="y",
            line=dict(color=THEME["text_primary"], width=2, dash="dash"),
        )

    if "NVDA Total" in factors:
        nvda_pos = factors.index("NVDA Total")
        fig.add_shape(
            type="line",
            x0=-0.5,            x1=len(snap_labels) - 0.5,
            y0=nvda_pos - 0.5,  y1=nvda_pos - 0.5,
            xref="x", yref="y",
            line=dict(color=THEME["border_subtle"], width=1),
        )

    apply_base_layout(
        fig,
        title    = title,
        height   = 460,
        margin   = dict(t=20, b=30, l=120, r=10),
        dragmode = False,
    )

    fig.update_xaxes(fixedrange=True)
    fig.update_yaxes(autorange="reversed", fixedrange=True)
    return fig


