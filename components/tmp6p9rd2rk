def apply_base_layout(
    fig        : go.Figure,
    title      : str  = None,
    height     : int  = 400,
    margin     : dict = None,
    hovermode  : str  = "x unified",
    showlegend : bool = True,
    dragmode         = "zoom",
    legend_style : dict = None,
) -> go.Figure:
    """
    Applies the shared BASE_LAYOUT to any Plotly figure, then overlays
    per-call overrides. All chart factory functions call this as their
    last step before returning.

    Args:
        fig          : The Plotly figure to style.
        title        : If provided, adds a standard top-left title annotation.
        height       : Figure height in pixels.
        margin       : Override default margin dict(l=8, r=8, t=44, b=8).
        hovermode    : Plotly hovermode string.
        showlegend   : Whether to show the legend.
        dragmode     : Plotly dragmode ('zoom', 'pan', False, etc.)
        legend_style : Pass _LEGEND_H or _LEGEND_V (defaults to _LEGEND_H).
    """
    _margin = margin or dict(l=8, r=8, t=44, b=8)
    _legend = legend_style or _LEGEND_H

    layout = dict(
        paper_bgcolor = THEME["chart_bg"],
        plot_bgcolor  = THEME["chart_bg"],
        font          = dict(
            family = THEME["font_family"],
            size   = THEME["font_size_base"],
            color  = THEME["text_primary"],
        ),
        height     = height,
        margin     = _margin,
        hovermode  = hovermode,
        showlegend = showlegend,
        dragmode   = dragmode,
        legend     = _legend,
    )

    if title:
        layout["annotations"] = [_title_annotation(title)]

    fig.update_layout(**layout)

    # Apply axis defaults — individual chart functions can override after this
    fig.update_xaxes(**_XAXIS_BASE)
    fig.update_yaxes(**_YAXIS_BASE)

    return fig


