def plot_predictability_scatter(
    scatter_data: dict,
    x_type: str, x_offset: int,
    y_type: str, y_offset: int,
    series: str,
) -> go.Figure:
    labels, x_vals, y_vals = [], [], []

    for label, event in scatter_data.items():
        xs = event[x_type].get(x_offset)
        ys = event[y_type].get(y_offset)
        if xs is None or ys is None:
            continue
        x_vals.append(xs[series])
        y_vals.append(ys[series])
        labels.append(label)

    fig = go.Figure()
    fig.add_hline(y=0, line=dict(color=THEME["border_subtle"], width=1))
    fig.add_vline(x=0, line=dict(color=THEME["border_subtle"], width=1))

    fig.add_trace(go.Scatter(
        x            = x_vals,
        y            = y_vals,
        mode         = "markers+text",
        text         = labels,
        textposition = "top center",
        textfont     = dict(size=THEME["font_size_caption"],
                            color=THEME["text_muted"]),
        marker       = dict(
            color = THEME["primary"],
            size  = 9,
            line  = dict(color="white", width=1),
        ),
        hovertemplate = (
            "<b>%{text}</b><br>"
            "X: %{x:.2f}%<br>Y: %{y:.2f}%<extra></extra>"
        ),
        showlegend = False,
    ))

    x_label      = _metric_label(x_type, x_offset)
    y_label      = _metric_label(y_type, y_offset)
    series_label = "Idiosyncratic" if series == "idio" else "Total"

    apply_base_layout(
        fig,
        title    = f"{series_label} — {x_label} vs {y_label}",
        height   = 260,
        margin   = dict(t=36, b=40, l=50, r=10),
        hovermode= "closest",
        dragmode = False,
    )

    fig.update_xaxes(
        title      = dict(text=x_label, font=dict(size=THEME["font_size_body"])),
        showgrid   = True,
        gridcolor  = THEME["chart_grid"],
        ticksuffix = "%",
        fixedrange = True,
    )
    fig.update_yaxes(
        title      = dict(text=y_label, font=dict(size=THEME["font_size_body"])),
        showgrid   = True,
        gridcolor  = THEME["chart_grid"],
        ticksuffix = "%",
        fixedrange = True,
    )
    return fig


