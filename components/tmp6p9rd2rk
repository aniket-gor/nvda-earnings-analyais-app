def plot_drawdown(df: pd.DataFrame, earnings_dates: list) -> go.Figure:

    def to_drawdown(series: pd.Series) -> pd.Series:
        cumret = (1 + series).cumprod()
        return (cumret / cumret.cummax()) - 1

    dd_total = to_drawdown(df["nvda_return"])
    dd_sys   = to_drawdown(df["systematic_return"])
    dd_idio  = to_drawdown(df["idio_return"])

    fig = go.Figure()

    for dd, label, visible in [
        (dd_total, "Total",         True),
        (dd_sys,   "Systematic",    False),
        (dd_idio,  "Idiosyncratic", False),
    ]:
        color = RETURN_COLORS[label]
        fig.add_trace(go.Scatter(
            x             = df.index,
            y             = dd * 100,
            mode          = "lines",
            name          = label,
            line          = dict(color=color, width=1.5),
            fill          = "tozeroy",
            fillcolor     = _hex_to_rgba(color, 0.08),
            visible       = visible,
            hovertemplate = "%{x|%b %d, %Y}<br>Drawdown: %{y:.1f}%<extra></extra>",
        ))

    for ed in earnings_dates:
        fig.add_vline(
            x    = pd.Timestamp(ed).timestamp() * 1000,
            line = dict(color=THEME["earnings_line"], width=1, dash="dot"),
        )

    fig.update_layout(updatemenus=[dict(
        type       = "buttons",
        direction  = "right",
        x=1.0,     xanchor="right",
        y=1.0,     yanchor="bottom",
        showactive = True,
        active     = 0,
        buttons    = [
            dict(label="Total",
                 method="update",
                 args=[{"visible": [True, False, False]},
                       {"annotations": [_title_annotation("Total Returns Drawdown",
                                        size=THEME["font_size_title"])]}]),
            dict(label="Systematic",
                 method="update",
                 args=[{"visible": [False, True, False]},
                       {"annotations": [_title_annotation("Systematic Returns Drawdown",
                                        size=THEME["font_size_title"])]}]),
            dict(label="Idiosyncratic",
                 method="update",
                 args=[{"visible": [False, False, True]},
                       {"annotations": [_title_annotation("Idiosyncratic Returns Drawdown",
                                        size=THEME["font_size_title"])]}]),
        ],
        **_UPDATEMENU_STYLE,
    )])

    apply_base_layout(
        fig,
        height     = 240,
        margin     = dict(t=44, b=30, l=40, r=10),
        showlegend = False,
        hovermode  = "x unified",
        dragmode   = False,
    )

    fig.update_yaxes(
        ticksuffix    = "%",
        zeroline      = True,
        zerolinecolor = THEME["border_subtle"],
        zerolinewidth = 1,
    )
    fig.add_annotation(_title_annotation("Total Returns Drawdown",
                                         size=THEME["font_size_title"]))
    return fig


