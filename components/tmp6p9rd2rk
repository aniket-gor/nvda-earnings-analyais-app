def plot_explorer_histogram(series: pd.Series, label: str) -> go.Figure:
    vals  = series.dropna()
    mean  = vals.mean()
    std   = vals.std()

    fig = go.Figure()

    fig.add_trace(go.Histogram(
        x          = vals,
        nbinsx     = 40,
        name       = label,
        marker     = dict(
            color = _hex_to_rgba(THEME["primary"], 0.7),
            line  = dict(color=THEME["bg_panel"], width=0.5),
        ),
        showlegend = False,
        hovertemplate = "%{x:.4f}<br>Count: %{y}<extra></extra>",
    ))

    for x_val, dash, color, annotation in [
        (mean,       "solid", THEME["primary"],   f"μ = {mean:.4f}"),
        (mean + std, "dash",  THEME["neutral"],   f"+1σ"),
        (mean - std, "dash",  THEME["neutral"],   f"−1σ"),
    ]:
        fig.add_vline(
            x                   = x_val,
            line                = dict(color=color, width=1.2, dash=dash),
            annotation_text     = annotation,
            annotation_position = "top",
            annotation_font     = dict(size=THEME["font_size_caption"],
                                       color=color),
        )

    apply_base_layout(
        fig,
        title    = f"{label} — Distribution",
        height   = 220,
        margin   = dict(t=44, b=30, l=40, r=10),
        hovermode= "x",
        dragmode = False,
    )

    fig.update_xaxes(title=dict(text=label,
                                font=dict(size=THEME["font_size_body"])))
    fig.update_yaxes(title=dict(text="Count",
                                font=dict(size=THEME["font_size_body"])),
                     showgrid=True, gridcolor=THEME["chart_grid"])
    return fig


