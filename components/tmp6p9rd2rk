def _hex_to_rgba(hex_color: str, alpha: float = 1.0) -> str:
    """
    Convert #RRGGBB to rgba(r, g, b, alpha).
    Used for fill colors that need transparency from a solid hex token.
    """
    h = hex_color.lstrip("#")
    r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
    return f"rgba({r},{g},{b},{alpha})"


def _title_annotation(text: str, size: int = None) -> dict:
    """
    Standard top-left chart title annotation.
    All chart functions call this instead of hand-writing annotation dicts.
    """
    return dict(
        text    = text,
        x=0.0,  y=1.0,
        xref    = "paper",
        yref    = "paper",
        xanchor = "left",
        yanchor = "bottom",
        showarrow = False,
        font    = dict(
            size   = size or THEME["font_size_title"],
            family = THEME["font_family"],
            color  = THEME["text_primary"],
        ),
    )


