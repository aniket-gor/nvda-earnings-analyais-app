def plot_rolling_vol(
    vol_data: dict,
    window: int,
    series: str,
    zoom_event: str = None,
) -> go.Figure:
    from plotly.subplots import make_subplots

    dates       = vol_data["dates"]
    daily       = vol_data["daily"]
    rolling_vol = vol_data["rolling_vol"]
    earnings    = vol_data["earnings"]

    sorted_earnings = sorted(earnings)
    if zoom_event:
        from backend.compute import _quarter_label
        d0    = next((e for e in sorted_earnings
                      if _quarter_label(e) == zoom_event), None)
        if d0:
            prev_e = [e for e in sorted_earnings if e < d0]
            next_e = [e for e in sorted_earnings if e > d0]
            x_min  = prev_e[-1] if prev_e else dates[0]
            x_max  = next_e[0]  if next_e else dates[-1]
        else:
            x_min, x_max = dates[0], dates[-1]
    else:
        x_min, x_max = dates[0], dates[-1]

    series_label = "Idiosyncratic" if series == "idio" else "Total"

    fig = make_subplots(specs=[[{"secondary_y": True}]])

    bar_colors = [
        _hex_to_rgba(THEME["primary"],  0.25) if v >= 0
        else _hex_to_rgba(THEME["negative"], 0.25)
        for v in daily
    ]
    fig.add_trace(go.Bar(
        x             = dates,
        y             = daily,
        name          = f"{series_label} Return",
        marker_color  = bar_colors,
        hovertemplate = "%{x|%b %d, %Y}<br>Return: %{y:.2f}%<extra></extra>",
        showlegend    = True,
    ), secondary_y=True)

    fig.add_trace(go.Scatter(
        x             = dates,
        y             = rolling_vol,
        name          = f"{window}d Vol",
        mode          = "lines",
        line          = dict(color=THEME["primary"], width=1.8),
        hovertemplate = "%{x|%b %d, %Y}<br>Vol: %{y:.1f}%<extra></extra>",
        showlegend    = True,
    ), secondary_y=False)

    for ed in earnings:
        fig.add_vline(
            x       = pd.Timestamp(ed).timestamp() * 1000,
            line    = dict(color=THEME["earnings_line"], width=1, dash="dash"),
            opacity = 0.8,
        )

    apply_base_layout(
        fig,
        title        = f"Rolling {window}d {series_label} Volatility",
        height       = 280,
        margin       = dict(t=44, b=30, l=50, r=50),
        hovermode    = "x unified",
        showlegend   = True,
        legend_style = dict(
            font        = dict(size=THEME["font_size_caption"],
                               family=THEME["font_family"]),
            orientation = "h",
            x=0.0, y=-0.15,
            bgcolor     = "rgba(0,0,0,0)",
        ),
    )

    fig.update_xaxes(range=[x_min, x_max], fixedrange=False)

    fig.update_yaxes(
        title_text  = "Ann. Vol (%)",
        ticksuffix  = "%",
        showgrid    = True,
        gridcolor   = THEME["chart_grid"],
        secondary_y = False,
    )
    fig.update_yaxes(
        title_text  = "Daily Return (%)",
        ticksuffix  = "%",
        showgrid    = False,
        secondary_y = True,
    )
    fig.update_layout(barmode="overlay")
    return fig


