def plot_factor_detail_bar_multi(all_details: dict) -> go.Figure:
    fig = go.Figure()

    for idx, (factor_name, detail) in enumerate(all_details.items()):
        if not detail["labels"]:
            continue
        fig.add_trace(go.Bar(
            name          = factor_name,
            x             = detail["labels"],
