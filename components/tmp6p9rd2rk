def plot_car_heatmap(
    car_data: dict,
    selected_event: str = None,
) -> go.Figure:
    rows        = car_data["rows"]
    snap_labels = car_data["snap_labels"]
    z           = car_data["z"]
    max_val     = max(abs(v) for row in z for v in row if v is not None) or 1.0

    fig = go.Figure(go.Heatmap(
        z             = z,
        x             = snap_labels,
        y             = rows,
        colorscale    = DIVERGING_RdGn_SOFT,
        zmid=0,
        zmin=-max_val,
        zmax=max_val,
        xgap=0, ygap=0,
        text          = [[f"{v:.1f}" if v is not None else "" for v in row] for row in z],
        texttemplate  = "%{text}%",
        textfont      = dict(size=THEME["font_size_caption"],
                             color=THEME["text_primary"]),
        colorbar      = dict(
            ticksuffix = "%",
            tickfont   = dict(size=THEME["font_size_caption"]),
            thickness  = 10,
            len        = 0.8,
        ),
        hovertemplate = (
            "<b>%{y}</b><br>%{x}<br>"
            "CAR: %{z:.2f}%<extra></extra>"
        ),
    ))

    if "D0" in snap_labels:
        d0_pos = snap_labels.index("D0")
        fig.add_shape(
            type="line",
            x0=d0_pos + 0.5, x1=d0_pos + 0.5,
            y0=-0.5,          y1=len(rows) - 0.5,
            xref="x", yref="y",
            line=dict(color=THEME["text_primary"], width=2, dash="dash"),
        )

    if selected_event and selected_event in rows:
        row_pos = rows.index(selected_event)
        fig.add_shape(
            type="rect",
            x0=-0.5,              x1=len(snap_labels) - 0.5,
            y0=row_pos - 0.5,     y1=row_pos + 0.5,
            xref="x", yref="y",
            line=dict(color=THEME["primary"], width=2),
            fillcolor="rgba(0,0,0,0)",
        )

    apply_base_layout(
        fig,
        title    = "Cumulative Abnormal Returns",
        height   = 360,
        margin   = dict(t=28, b=16, l=80, r=10),
        dragmode = False,
    )

    fig.update_xaxes(fixedrange=True)
    fig.update_yaxes(autorange=True, fixedrange=True)
    return fig


