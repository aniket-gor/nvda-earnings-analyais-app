def plot_car_line_chart(
    car_lines: dict,
    selected_event: str = None,
) -> go.Figure:
    day_offsets = car_lines["day_offsets"]
    per_event   = car_lines["per_event"]
    average     = car_lines["average"]

    fig = go.Figure()

    fig.add_hline(y=0, line=dict(color=THEME["border_subtle"], width=1))

    fig.add_vline(
        x=0,
        line=dict(color=THEME["neutral"], width=1.5, dash="dash"),
        annotation_text     = "D0",
        annotation_position = "top",
        annotation_font     = dict(size=THEME["font_size_caption"],
                                   color=THEME["text_muted"]),
    )
    fig.add_vline(
        x=1,
        line=dict(color=THEME["earnings_line"], width=1.5, dash="dot"),
        annotation_text     = "Earnings Reaction",
        annotation_position = "top right",
        annotation_font     = dict(size=THEME["font_size_caption"],
                                   color=THEME["earnings_line"]),
    )

    for label, car_vals in per_event.items():
        is_sel   = label == selected_event
        is_other = selected_event is not None and not is_sel
        fig.add_trace(go.Scatter(
            x          = day_offsets,
            y          = car_vals,
            mode       = "lines",
            name       = label,
            line       = dict(
                color  = THEME["earnings_line"] if is_sel else
                         THEME["border_subtle"]  if is_other else
                         THEME["neutral"],
                width  = 2.5 if is_sel else 0.8,
            ),
            opacity    = 1.0 if is_sel else 0.35,
            showlegend = is_sel,
            hovertemplate = (
                f"<b>{label}</b><br>"
                "Day: %{x}<br>CAR: %{y:.2f}%<extra></extra>"
            ),
        ))

    fig.add_trace(go.Scatter(
        x          = day_offsets,
        y          = average,
        mode       = "lines",
        name       = "Average",
        line       = dict(
            color  = THEME["neutral"]  if selected_event else THEME["primary"],
            width  = 2.5,
            dash   = "dot" if selected_event else "solid",
        ),
        opacity    = 0.6 if selected_event else 1.0,
        showlegend = True,
        hovertemplate = (
            "<b>Average</b><br>"
            "Day: %{x}<br>CAR: %{y:.2f}%<extra></extra>"
        ),
    ))

    apply_base_layout(
        fig,
        title        = "Cumulative Abnormal Return drift (PEAD check)",
        height       = 400,
        margin       = dict(t=44, b=0, l=50, r=10),
        hovermode    = "closest",
        showlegend   = True,
        dragmode     = False,
        legend_style = _LEGEND_V,
    )

    fig.update_xaxes(
        title     = dict(text="Days relative to D0",
                         font=dict(size=THEME["font_size_body"])),
        showgrid  = True,
        gridcolor = THEME["chart_grid"],
        fixedrange= True,
    )
    fig.update_yaxes(
        ticksuffix = "%",
        showgrid   = True,
        gridcolor  = THEME["chart_grid"],
        fixedrange = True,
    )
    return fig


