def plot_factor_heatmap(contrib: pd.DataFrame) -> go.Figure:
    """
    Full-period factor contribution heatmap.
    Factors as rows, dates as columns.
    """
    factors = [c for c in contrib.columns if c != "Idiosyncratic"] + ["Idiosyncratic"]
    z       = (contrib[factors] * 100).T.values
    max_val = float(np.abs(z).max())

    fig = go.Figure(go.Heatmap(
        z         = z,
        x         = contrib.index,
        y         = factors,
        colorscale = DIVERGING_RdGn,
        zmid=0,
        zmin=-max_val,
        zmax=max_val,
        colorbar  = dict(
            ticksuffix = "%",
            tickfont   = dict(size=THEME["font_size_caption"]),
            thickness  = 10,
            len        = 0.8,
        ),
        hovertemplate = (
            "<b>%{y}</b><br>"
            "%{x|%b %d, %Y}<br>"
            "Contribution: %{z:.2f}%<extra></extra>"
        ),
    ))

    apply_base_layout(
        fig,
        title  = "Factor Contribution Heatmap",
        height = 520,
        margin = dict(t=44, b=30, l=120, r=10),
        dragmode = "zoom",
    )

    fig.update_xaxes(fixedrange=False)
    fig.update_yaxes(autorange="reversed", fixedrange=True)
    return fig


