def plot_returns_and_equity(
    df: pd.DataFrame,
    earnings_dates: list,
    factor_overlays: list = None,
    df_returns: pd.DataFrame = None,
    show_earnings_line: bool = True,
    show_earnings_band: bool = False,
) -> go.Figure:
    from plotly.subplots import make_subplots

    factor_overlays = factor_overlays or []

    fig = make_subplots(
        rows=2, cols=1,
        shared_xaxes=True,
        vertical_spacing=0.06,
        row_heights=[0.45, 0.55],
    )

    series_map = {
        "Total"         : "nvda_return",
        "Systematic"    : "systematic_return",
        "Idiosyncratic" : "idio_return",
    }

    if show_earnings_band:
        trading_days = df.index.tolist()
        for ed in earnings_dates:
            ed   = pd.Timestamp(ed)
            pre  = [d for d in trading_days if d <= ed]
            post = [d for d in trading_days if d >  ed]
            x0   = pre[-5]  if len(pre)  >= 5 else pre[0]
            x1   = post[4]  if len(post) >= 5 else post[-1]
            for row in [1, 2]:
                fig.add_vrect(
                    x0=x0, x1=x1,
                    fillcolor  = THEME["earnings_line"],
                    opacity    = 0.08,
                    layer      = "below",
                    line_width = 0,
                    row=row, col=1,
                )

    for i, (label, col) in enumerate(series_map.items()):
        r      = df[col] * 100
        colors = [THEME["positive"] if v >= 0 else THEME["negative"] for v in r]
        fig.add_trace(go.Bar(
            x             = df.index,
            y             = r,
            name          = label,
            marker_color  = colors,
            visible       = (i == 0),
            showlegend    = False,
            hovertemplate = "%{x|%b %d, %Y}<br>Return: %{y:.3f}%<extra></extra>",
        ), row=1, col=1)

    for label, col in series_map.items():
        equity = (1 + df[col]).cumprod()
        fig.add_trace(go.Scatter(
            x             = df.index,
            y             = equity,
            name          = label,
            mode          = "lines",
            line          = dict(color=RETURN_COLORS[label], width=1.8),
            showlegend    = True,
            hovertemplate = "%{x|%b %d, %Y}<br>$%{y:.3f}<extra>" + label + "</extra>",
        ), row=2, col=1)

    if factor_overlays and df_returns is not None:
        for j, factor in enumerate(factor_overlays):
            col_name = f"ret_{factor}"
            if col_name in df_returns.columns:
                equity = (1 + df_returns[col_name]).cumprod()
                fig.add_trace(go.Scatter(
                    x             = df.index,
                    y             = equity,
                    name          = factor,
                    mode          = "lines",
                    line          = dict(
                        color = FACTOR_OVERLAY_COLORS[j % len(FACTOR_OVERLAY_COLORS)],
                        width = 1.2,
                        dash  = "dot",
                    ),
                    showlegend    = True,
                    hovertemplate = "%{x|%b %d, %Y}<br>$%{y:.3f}<extra>" + factor + "</extra>",
                ), row=2, col=1)

    if show_earnings_line:
        for ed in earnings_dates:
            ts = pd.Timestamp(ed).timestamp() * 1000
            for row in [1, 2]:
                fig.add_vline(
                    x          = ts,
                    line_width = 1,
                    line_dash  = "dash",
                    line_color = THEME["earnings_line"],
                    opacity    = 0.8,
                    row=row, col=1,
                )

    n_bar    = len(series_map)
    n_eq     = len(series_map)
    n_factor = len(factor_overlays)

    series_buttons = []
    for i, label in enumerate(series_map.keys()):
        series_buttons.append(dict(
            label  = label,
            method = "update",
            args   = [
                {"visible": [j == i for j in range(n_bar)] + [True]*n_eq + [True]*n_factor},
                {"annotations[0].text": f"{label} Daily Returns"},
            ],
        ))

    fig.update_layout(updatemenus=[dict(
        type       = "buttons",
        direction  = "right",
        x=1.0,     xanchor="right",
        y=1.0,     yanchor="bottom",
        showactive = False,
        buttons    = series_buttons,
        **_UPDATEMENU_STYLE,
    )])

    apply_base_layout(
        fig,
        height       = 520,
        margin       = dict(l=8, r=8, t=36, b=8),
        hovermode    = "x unified",
        showlegend   = True,
        legend_style = _LEGEND_H,
    )

    fig.update_xaxes(showspikes=False)
    fig.update_yaxes(showspikes=False)
    fig.update_yaxes(ticksuffix="%", row=1, col=1)
    fig.update_yaxes(tickprefix="$", row=2, col=1)
    fig.add_annotation(_title_annotation("Total Daily Returns",
                                         size=THEME["font_size_title"]))
    return fig


